# Platinum Tier - Local Environment Configuration
# Copy this file to .env in the Platinum-Tier root directory
# This configuration is for the Local machine (your computer)

# ============================================================================
# AGENT MODE (REQUIRED)
# ============================================================================
AGENT_MODE=local

# ============================================================================
# VAULT PATH (REQUIRED)
# ============================================================================
# Windows: C:/Users/YourName/Platinum-Tier/Vault
# Mac/Linux: /Users/yourname/Platinum-Tier/Vault
VAULT_PATH=/Users/yourname/Platinum-Tier/Vault

# ============================================================================
# SMTP CONFIGURATION (REQUIRED FOR LOCAL)
# ============================================================================
# Local agent has FULL access to SMTP for sending emails
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ============================================================================
# ODOO CONFIGURATION (FULL ACCESS)
# ============================================================================
# Local agent has FULL WRITE access to Odoo
ODOO_URL=http://localhost:8069
ODOO_USERNAME=admin
ODOO_PASSWORD=admin_password
ODOO_DATABASE=your_database

# ============================================================================
# WHATSAPP CONFIGURATION (OPTIONAL)
# ============================================================================
# Local agent has access to WhatsApp session
WHATSAPP_SESSION_PATH=/path/to/whatsapp_session

# ============================================================================
# SOCIAL MEDIA SESSIONS (OPTIONAL)
# ============================================================================
# Local agent has access to social media sessions
LINKEDIN_SESSION_PATH=/path/to/linkedin_session
FACEBOOK_SESSION_PATH=/path/to/facebook_session

# ============================================================================
# BANKING/PAYMENT (OPTIONAL)
# ============================================================================
# Local agent has access to banking/payment credentials
BANKING_API_KEY=your-banking-api-key
PAYMENT_TOKEN=your-payment-token

# ============================================================================
# OPENAI API
# ============================================================================
OPENAI_API_KEY=sk-your-local-openai-key

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_PATH=/path/to/Platinum-Tier/Logs/local

# ============================================================================
# SYNC CONFIGURATION
# ============================================================================
# Git sync interval (seconds)
SYNC_INTERVAL=300

# Git repository URL
GIT_REPO_URL=https://github.com/your-username/platinum-vault.git

# Git credentials (if using HTTPS)
GIT_USERNAME=your-github-username
GIT_TOKEN=your-github-token

# ============================================================================
# HEALTH MONITORING
# ============================================================================
# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=600

# ============================================================================
# TASK PROCESSING
# ============================================================================
# Scan interval (seconds)
SCAN_INTERVAL=300

# Max concurrent tasks
MAX_CONCURRENT_TASKS=3

# ============================================================================
# DASHBOARD
# ============================================================================
# Dashboard path (Local only)
DASHBOARD_PATH=/path/to/Platinum-Tier/Dashboard.md

# ============================================================================
# SECURITY NOTES
# ============================================================================
# Local environment has FULL ACCESS to all secrets and services.
# This file should NEVER be synced to Git or Cloud VM.
# Keep this file secure and backed up locally only.
# ============================================================================
