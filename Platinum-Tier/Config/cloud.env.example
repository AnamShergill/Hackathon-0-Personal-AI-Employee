# Platinum Tier - Cloud Environment Configuration
# Copy this file to .env in the Platinum-Tier root directory
# This configuration is for the Cloud VM (Oracle Cloud Free Tier)

# ============================================================================
# AGENT MODE (REQUIRED)
# ============================================================================
AGENT_MODE=cloud

# ============================================================================
# VAULT PATH (REQUIRED)
# ============================================================================
VAULT_PATH=/home/ubuntu/Platinum-Tier/Vault

# ============================================================================
# ODOO CONFIGURATION (READ-ONLY)
# ============================================================================
# Cloud agent has READ-ONLY access to Odoo
ODOO_URL=https://your-odoo-instance.com
ODOO_READONLY_USER=readonly_user
ODOO_READONLY_PASS=readonly_password
ODOO_DATABASE=your_database

# ============================================================================
# OPENAI API
# ============================================================================
OPENAI_API_KEY=sk-your-cloud-openai-key

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_PATH=/home/ubuntu/Platinum-Tier/Logs/cloud

# ============================================================================
# SYNC CONFIGURATION
# ============================================================================
# Git sync interval (seconds)
SYNC_INTERVAL=60

# Git repository URL
GIT_REPO_URL=https://github.com/your-username/platinum-vault.git

# Git credentials (if using HTTPS)
GIT_USERNAME=your-github-username
GIT_TOKEN=your-github-token

# ============================================================================
# HEALTH MONITORING
# ============================================================================
# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=300

# Stale claim detection (minutes)
STALE_CLAIM_THRESHOLD=30

# ============================================================================
# TASK PROCESSING
# ============================================================================
# Scan interval (seconds)
SCAN_INTERVAL=30

# Max concurrent tasks
MAX_CONCURRENT_TASKS=5

# ============================================================================
# FORBIDDEN VARIABLES (DO NOT SET IN CLOUD)
# ============================================================================
# The following variables should NEVER be set in Cloud environment:
# - SMTP_USER
# - SMTP_PASS
# - SMTP_SERVER
# - SMTP_PORT
# - WHATSAPP_SESSION_PATH
# - BANKING_API_KEY
# - PAYMENT_TOKEN
# - LINKEDIN_SESSION
# - FACEBOOK_SESSION
#
# Cloud agent has NO access to these secrets for security reasons.
# ============================================================================
